# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/buildrai

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Application URL (for OAuth callbacks)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Anthropic API Key
ANTHROPIC_API_KEY=sk-ant-...

# Token Encryption Key (generate a strong random key)
# You can generate one using: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=your-very-strong-encryption-key-here

# GitHub OAuth (for repository integration)
# Create an OAuth app at: https://github.com/settings/developers
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Bitbucket OAuth (for repository integration)
# Create an OAuth consumer at: https://bitbucket.org/account/settings/app-passwords/
BITBUCKET_CLIENT_ID=your-bitbucket-client-id
BITBUCKET_CLIENT_SECRET=your-bitbucket-client-secret

# Azure Repos OAuth (for repository integration)
# Register an application at: https://app.vsaex.visualstudio.com/app/register
AZURE_CLIENT_ID=your-azure-client-id
AZURE_CLIENT_SECRET=your-azure-client-secret
